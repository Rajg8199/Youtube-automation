# ============ PhoneWala Gyan — environment ============
# Copy to .env and fill. NEVER commit .env. Rotation: see docs/runbook.md.

# ---- Stack tier ----
# free = Gemini (free) + Edge TTS + BGE-M3 -> $0/month; budget/premium use Claude.
STACK_TIER=budget            # free | budget | premium

# ---- Database (local docker compose defaults) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=phonewala
DB_PORT=54322
DATABASE_URL=postgresql://postgres:postgres@db:5432/phonewala
# For host-side tools (worker run outside docker), use localhost:${DB_PORT}:
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/phonewala

# ---- Worker / dashboard ----
WORKER_PORT=8000
WORKER_URL=http://localhost:8000

# ---- LLM ----
ANTHROPIC_API_KEY=                 # STACK_TIER=budget|premium
GEMINI_API_KEY=                    # STACK_TIER=free (get one at aistudio.google.com/apikey)

# ---- Phase 1: research -> scored topics ----
# Set USE_MOCK_PROVIDERS=true for keyless dev (mock LLM + mock embeddings).
# Production: USE_MOCK_PROVIDERS=false, EMBEDDINGS_BACKEND=bge-m3, ANTHROPIC_API_KEY set.
USE_MOCK_PROVIDERS=false
EMBEDDINGS_BACKEND=bge-m3

# ---- TTS providers ----
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_CREDENTIALS=       # path to service-account JSON
# Edge TTS needs no key (free fallback)

# ---- Research ----
PEXELS_API_KEY=
PERPLEXITY_API_KEY=           # premium tier only

# ---- YouTube (OAuth2 refresh-token flow) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ---- Affiliate ----
AMAZON_ASSOCIATES_TAG=
FLIPKART_AFFILIATE_ID=

# ---- Cost guardrails (USD) ----
MONTHLY_COST_CAP_USD=50
PER_VIDEO_COST_CAP_USD=1

# ---- Supabase (cloud, later phases) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
