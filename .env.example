# ============ PhoneWala Gyan — environment ============
# Copy to .env and fill. NEVER commit .env. Rotation: see docs/runbook.md.

# ---- Stack tier ----
STACK_TIER=budget            # budget | premium

# ---- Database (local docker compose defaults) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=phonewala
DB_PORT=54322
DATABASE_URL=postgresql://postgres:postgres@db:5432/phonewala
# For host-side tools (worker run outside docker), use localhost:${DB_PORT}:
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/phonewala

# ---- Worker / dashboard ----
WORKER_PORT=8000
WORKER_URL=http://localhost:8000

# ---- LLM (Claude) ----
ANTHROPIC_API_KEY=

# ---- TTS providers ----
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_CREDENTIALS=       # path to service-account JSON
# Edge TTS needs no key (free fallback)

# ---- Research ----
PEXELS_API_KEY=
PERPLEXITY_API_KEY=           # premium tier only

# ---- YouTube (OAuth2 refresh-token flow) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ---- Affiliate ----
AMAZON_ASSOCIATES_TAG=
FLIPKART_AFFILIATE_ID=

# ---- Cost guardrails (USD) ----
MONTHLY_COST_CAP_USD=50
PER_VIDEO_COST_CAP_USD=1

# ---- Supabase (cloud, later phases) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
