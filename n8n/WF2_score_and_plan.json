      },
      "id": "http-scorer",
      "name": "Score new topics (topic_scorer)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [ 520, 300 ]
    }
  ],
  "connections": {
    "Daily 06:00 IST": { "main": [ [ { "node": "Score new topics (topic_scorer)", "type": "main", "index": 0 } ] ] }
